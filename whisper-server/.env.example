# TalkBro Server Configuration
# Copy this file to .env and fill in your actual values

# ═══════════════════════════════════════════════════════
# PRIMARY: Nvidia API Key for DeepSeek text enhancement
# ═══════════════════════════════════════════════════════
# Get your key from: https://build.nvidia.com/
# This is the primary service - fast and high quality
NVIDIA_API_KEY=your-nvidia-api-key-here

# ═══════════════════════════════════════════════════════
# FALLBACK: Ollama Configuration (Local LLM)
# ═══════════════════════════════════════════════════════
# Used automatically if Nvidia API fails or is not configured
# Install: https://ollama.ai/
# Start: ollama serve
# Pull model: ollama pull mistral

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ═══════════════════════════════════════════════════════
# Whisper Configuration
# ═══════════════════════════════════════════════════════
# Whisper model size (optional, default: base)
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base

# ═══════════════════════════════════════════════════════
# Server Configuration
# ═══════════════════════════════════════════════════════
# Server port (optional, default: 5555)
PORT=5555
